# ---------------------------------------------------------------------------
# Momentum+ environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# Every variable the app can use is listed here (see SPEC.md §4 Integrations).
# Phase 1 only requires the Supabase block; later phases add the rest.
# ---------------------------------------------------------------------------

# --- Supabase (Phase 1: auth + database) ------------------------------------
# Project URL and keys from supabase.com → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only (webhooks, imports, admin actions). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the app (used for auth redirects / magic links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Go High Level (Phase 3: billing source of truth) -----------------------
GHL_API_KEY=
GHL_LOCATION_ID=
# Shared secret for /api/webhooks/ghl. The GHL workflow sends either
# x-ghl-signature (hex HMAC-SHA256 of the body) or x-webhook-secret (verbatim).
GHL_WEBHOOK_SECRET=
# JSON map: GHL product id -> tier. Payments for unmapped products are skipped.
# Example: {"prod_abc":"sub_monthly","prod_def":"sub_3mo","prod_ghi":"sub_6mo","prod_jkl":"sub_annual"}
GHL_PRODUCT_TIER_MAP=
# Public GHL checkout/renewal link shown on the /expired page.
NEXT_PUBLIC_GHL_RENEW_URL=

# --- Google Sheets (Phase 3: TSLS registration import) ----------------------
# Share the registration sheet with this service account (edit access so the
# import can mark rows processed). Private key keeps its \n escapes in .env.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
TSLS_REGISTRATION_SHEET_ID=
# Range read by the import (header row first). Default: Sheet1!A1:Z
TSLS_SHEET_RANGE=
# Import idempotency year (defaults to the current year).
TSLS_EVENT_YEAR=
# JSON map: registration type (lowercased) -> tier + months. VIP defaults to
# tsls_vip/3 months per spec; every other type MUST be mapped here or its rows
# are skipped and reported. Example:
# {"general admission":{"tier":"tsls_attendee","months":1}}
TSLS_TYPE_MAP=

# --- Zoom (Phase 2) ---------------------------------------------------------
# App (a): Server-to-Server OAuth — meeting creation + attendance reports.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Secret Token from the same Zoom app (Feature -> Event Subscriptions) —
# verifies the recording.completed webhook that auto-imports recordings.
ZOOM_WEBHOOK_SECRET_TOKEN=
# App (b): Meeting SDK app — powers the in-page embedded live room.
# The signature is minted server-side; the secret must stay server-only.
ZOOM_SDK_CLIENT_ID=
ZOOM_SDK_CLIENT_SECRET=

# --- Stream Chat (Phase 4: community) ---------------------------------------
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=

# --- Mux (Phase 5: video) ---------------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# --- Anthropic (Phase 5: AI session summaries) ------------------------------
ANTHROPIC_API_KEY=

# --- Cron protection (Vercel cron routes) -----------------------------------
CRON_SECRET=

# --- Zapier / inbound onboarding webhook -------------------------------------
# Shared secret for POST /api/webhooks/zapier (header: x-api-key). Generate a
# long random string. Zapier action body: {"email","name","plan"} where plan is
# monthly | 3month | 6month | 12month | annual | attendee | vip | speaker.
ZAPIER_WEBHOOK_SECRET=
