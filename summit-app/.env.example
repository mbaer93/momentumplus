# TSLS Summit Companion — environment variables
# Copy to .env.local for local dev. On Vercel, set these on the summit
# project. NOTHING here belongs to Momentum+ — this app has its own
# Supabase project and its own Stream app, by design.

# --- Supabase (this app's OWN project — NOT the Momentum+ one) ---
NEXT_PUBLIC_SUPABASE_URL=            # e.g. https://tslscompanion.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon/public key
SUPABASE_SERVICE_ROLE_KEY=           # server-only; importer + admin actions

# --- Stream Chat (this app's OWN Stream app — separate event community) ---
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=

# --- Registration import (READ-ONLY view of the live TSLS sheet) ---
# Share the sheet with this service account as a VIEWER. The readonly scope
# means this app physically cannot write to the sheet.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=  # keep \n escapes as-is from the JSON key
TSLS_REGISTRATION_SHEET_ID=          # the same live registration sheet
TSLS_SHEET_RANGE=                    # optional, default Sheet1!A1:Z
TSLS_EVENT_YEAR=2026
CRON_SECRET=                         # Vercel sends this as the cron bearer token

# --- Admins ---
SUMMIT_ADMIN_EMAILS=                 # comma-separated, e.g. matt@socialdrivemedia.com

# --- URLs ---
NEXT_PUBLIC_SITE_URL=                # this app's domain, e.g. https://app.thetsls.com
NEXT_PUBLIC_MOMENTUM_URL=            # Momentum+ domain; ONLY shown after the
                                     # on-stage announcement toggle in /admin
