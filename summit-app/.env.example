# TSLS Summit Companion — environment variables
# Copy to .env.local for local dev. On Vercel, set these on the summit
# project (separate from the Momentum+ project).

# --- Supabase (SHARED with Momentum+ — same project, same members) ---
NEXT_PUBLIC_SUPABASE_URL=            # e.g. https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon/public key
SUPABASE_SERVICE_ROLE_KEY=           # server-only; admin actions + event settings

# --- Stream Chat (SHARED with Momentum+ — one community, both apps) ---
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=

# --- URLs ---
NEXT_PUBLIC_SITE_URL=                # this app's domain, e.g. https://app.thetsls.com
NEXT_PUBLIC_MOMENTUM_URL=            # the Momentum+ domain, e.g. https://momentumplus.co
